# ============================================================================
# realtime-subtitle 配置示例
#
# 用法：复制本文件为 .env，按需取消注释并修改。
#   - 所有项都有内置默认值，未设置时使用默认值。
#   - 布尔值可写 1/true/yes/y/on（真）或 0/false/no/n/off（假）。
#   - 注释中标注的 [默认: xxx] 即为不设置时的取值。
#   - 切勿把含真实密钥的 .env 提交到版本库。
# ============================================================================


# ====================== 字幕服务器（托管/中转模式）=========================
# 可选。设置后，本程序可作为 subtitle-server 的客户端运行：无需自备 Soniox/
# Gemini 密钥，改用 VRChat（简介验证）登录，所有流量经服务器中转并按秒计费。
# 首次启动时用户可选择「托管模式」或「自带 key 模式」（之后可在设置中切换）。
# 不设置则仅保留传统的直连模式。
# 服务器地址只从这里读取，界面中不可修改。
# SUBTITLE_SERVER_URL="https://subtitle.example.com"
#
# 当前客户端构建内置版本。托管模式会拿它与服务器配置的最新/最低版本比较。
# [默认: 0.1.0]
# CLIENT_VERSION="0.1.0"
#
# 可选：预置账户令牌（长期 ss_ 密钥）。通常通过应用内登录流程获取；仅在无人值守/
# 自助终端部署时在此设置。
# SUBTITLE_SERVER_TOKEN=""


# ============================== 翻译/STT 后端 ===============================
# 使用哪个后端：soniox | gemini
# 一般在启动时交互式选择并写回 .env，这里可预先指定。
# 托管模式下，此项决定向哪个连接端点申请实际 WebSocket 地址
# （/relay/soniox/connect 或 /relay/gemini/connect）。
# TRANSLATION_PROVIDER="soniox"


# ================================= Soniox ===================================
# 持久 API key（填了它就不会再走临时 key 分发）
# SONIOX_API_KEY=""

# 临时 key 分发服务（未配置持久 key 时使用）
# SONIOX_TEMP_KEY_URL="https://your-dispenser.example.com"
# 请求临时 key 时附带的额外 HTTP 头（JSON 对象字符串）
# SONIOX_TEMP_KEY_HEADERS='{"Authorization": "Bearer your-token"}'

# WebSocket 端点 [默认: wss://stt-rt.soniox.com/transcribe-websocket]
# 区域端点：US=stt-rt.soniox.com / EU=stt-rt.eu.soniox.com / JP=stt-rt.jp.soniox.com
# SONIOX_WEBSOCKET_URL="wss://stt-rt.soniox.com/transcribe-websocket"

# 主动滚动重连：仅用于本地直连 Soniox 临时 key；这类流有硬性时长上限。
# 托管 relay 模式和持久 key 会忽略此项。
# SONIOX_STREAM_DURATION_SECONDS="170"

# 省流：长时间本地静音后断开当前 provider 的 WebSocket，检测到语音再重连。
# Soniox/Gemini 共用；默认在配置了持久 provider API key 时为 True，临时 key 时为 False。
# SLEEP_ON_SILENCE="True"
# SLEEP_IDLE_SECONDS="30"            # 进入休眠前的静音时长 [默认: 30]
# SLEEP_PRE_ROLL_SECONDS="1.0"       # 唤醒时回灌的预滚音频 [默认: 1.0]
# SLEEP_SPEECH_WINDOW_SECONDS="0.75" # 语音确认的最近窗口 [默认: 0.75]
# SLEEP_SPEECH_GRACE_SECONDS="0.5"   # 窗口内需要累计的语音时长 [默认: 0.5]
# SLEEP_VAD_THRESHOLD="0.2"          # Silero VAD 语音概率阈值 [默认: 0.5]


# ================================= Gemini ===================================
# 持久 API key
# GEMINI_API_KEY=""

# 临时 key 分发服务及请求头（与 Soniox 同理）
# GEMINI_TEMP_KEY_URL="https://your-dispenser.example.com"
# GEMINI_TEMP_KEY_HEADERS='{"Authorization": "Bearer your-token"}'

# Live API 端点 [默认见下行]
# GEMINI_WEBSOCKET_URL="wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1beta.GenerativeService.BidiGenerateContent"
# 模型 [默认: gemini-3.5-live-translate-preview]
# GEMINI_MODEL="gemini-3.5-live-translate-preview"

# 主动滚动重连（秒，需 >0）
# GEMINI_STREAM_DURATION_SECONDS="170"

# 也可以用 provider-specific 旧变量单独覆盖，例如 GEMINI_SLEEP_ON_SILENCE。

# 把夹在两个 CJK 字符之间的半角 , . ? ! 转为全角 ，。？！ [默认: True]
# GEMINI_FULLWIDTH_PUNCT_FIX="True"

# 发往 VRChat OSC 聊天框前，对阿拉伯文/希伯来文做显示重排 [默认: True]
# ENABLE_ARABIC_RESHAPER="True"


# ============================ 翻译目标语言 / 模式 ============================
# 自动使用系统语言作为翻译目标语言 [默认: True]
# 设为 False 时改用下方手动指定的 TARGET_LANG
# USE_SYSTEM_LANGUAGE="True"

# 手动指定的目标语言（USE_SYSTEM_LANGUAGE=False 时生效）
# TARGET_LANG="ja"
# 双向翻译的语言对（TRANSLATION_MODE=two_way 时生效）
# TARGET_LANG_1="en"
# TARGET_LANG_2="zh"

# 翻译模式：none（关闭）| one_way（单向）| two_way（双向） [默认: one_way]
# TRANSLATION_MODE="one_way"

# OSC 发送文本选择：smart（有翻译发翻译，同语言时发原文）|
#   translation_only（仅发翻译）| source_only（仅发原文） [默认: smart]
# OSC_SEND_TEXT_MODE="smart"

# 默认分句模式：translation（Soniox <end> 标记）|
#   endpoint（端点检测）| punctuation（句末标点） [默认: punctuation]
# DEFAULT_SEGMENT_MODE="punctuation"

# 修复 VRChat 嘈杂房间里的短暂打断（仅 Soniox）：
# A 说话、B 短暂插话、A 很快继续时，撤回 A 的前半句，并把 A1+A2
# 作为一句完整原文送给 LLM [默认: True]
# SONIOX_INTERRUPT_REPAIR_ENABLED="True"
# 插话者最大时长 [默认: 300 毫秒]
# SONIOX_INTERRUPT_MAX_DURATION_MS="300"
# 插话结束到原说话人继续的最大间隔 [默认: 1000 毫秒]
# SONIOX_INTERRUPT_RESUME_GAP_MS="1000"
# 要求插话文本在转小写、去标点/符号后精准命中语气词白名单 [默认: True]
# SONIOX_INTERRUPT_FILLER_WHITELIST_ENABLED="True"
# 逗号分隔的语气词白名单；匹配时大小写不敏感，去掉标点/符号后精准匹配
# SONIOX_INTERRUPT_FILLER_WHITELIST="啊,阿,呀,哎,唉,诶,欸,嗯,恩,唔,呃,额,呜,哦,噢,喔,嗷,哼,嗯嗯,呃呃,哦哦,啊啊,哎呀,哎哟,uh,uhh,uh-huh,um,umm,erm,er,ah,oh,o,ooh,oooh,eh,huh,hm,hmm,mm,mmm,yeah,yep,ya,yes,mhm,mhmm,うん,ううん,うーん,うわ,え,ええ,あ,ああ,お,おお,ほう,へえ,ふむ,ん,あの,えっと,まあ,えへ,えへへ,はい,はいはい,そう,そうそう,そうそうそう,そっか,なるほど,어,어어,음,응,응응,아,아아,오,에,으음,흠,네,네네,맞아,맞아맞아"


# ================================ 界面 / 行为 ===============================
# 启动时打开内置 WebView 窗口 [默认: True]
# False 时仅在控制台打印 URL，自行用浏览器打开（关网页不会退出程序）
# AUTO_OPEN_WEBVIEW="True"

# 锁定手动控制：隐藏前端重启/暂停/音源/OSC 等按钮并禁用相关后端操作 [默认: False]
# LOCK_MANUAL_CONTROLS="False"

# 说话人分离（仅 Soniox 支持；Gemini 强制关闭） [默认: True]
# ENABLE_SPEAKER_DIARIZATION="True"

# 隐藏说话人标签（即使开启了分离） [默认: False]
# HIDE_SPEAKER_LABELS="False"

# 启用绿幕（chroma）主题：加入主题循环，切到它会取消窗口置顶 [默认: False]
# ENABLE_CHROMA_THEME="False"

# 将字幕日志写入 logs/ 文件夹 [默认: False]
# ENABLE_TRANSCRIPT_LOG="True"


# ============================== 音频源 / 采集 ===============================
# 使用 Twitch 直播音频做转写（streamlink 拉流 + ffmpeg 提取 16kHz 单声道 PCM）
# [默认: False，即采集本地系统/麦克风音频]
# USE_TWITCH_AUDIO_STREAM="False"
# TWITCH_CHANNEL=""                  # 频道名（不含 https://www.twitch.tv/ 前缀）
# TWITCH_STREAM_QUALITY="audio_only" # 画质偏好（通常 audio_only / best）
# FFMPEG_PATH="ffmpeg"               # ffmpeg 可执行文件路径 [默认: 走 PATH]

# 当 VRChat MuteSelf=true 时静音麦克风分量 [默认: True]
# MUTE_MIC_WHEN_VRCHAT_SELF_MUTED="True"

# 混音权重（仅 mix 音源生效）：self=麦克风，others=系统回环
# 只需设一个，另一个自动取 1 - 该值，范围 0.0-1.0 [默认: 0.5]
# MIX_OWN_VOLUME="0.5"


# ================================= Web 服务 =================================
# 监听地址 [默认: 0.0.0.0]
# AUTO_OPEN_WEBVIEW=True 时强制绑定 127.0.0.1；关闭时默认 0.0.0.0 便于局域网访问
# SERVER_HOST="0.0.0.0"
# 端口 [默认: 8080]，设为 0 则自动选择可用端口
# SERVER_PORT="8080"


# ===================== LLM 润色 / 翻译（OpenAI 兼容） =======================
# 用于对已完成的翻译片段做轻度润色，让译文更准确、通顺、自然。需同时配置 BASE_URL、API_KEY、MODEL 才生效。
# LLM_BASE_URL="https://openrouter.ai/api/v1"
# 支持逗号分隔多个 key，运行时轮询使用
# LLM_API_KEY=""
# LLM_MODEL="openai/gpt-oss-120b:google-vertex"

# 启动时默认开启 LLM 润色 [默认: True]
# LLM_REFINE_DEFAULT_ENABLED="True"
# 默认模式：off | refine | translate [默认: 跟随上一项，开则 refine 否则 off]
# 仅在浏览器无历史记录或开启 LOCK_MANUAL_CONTROLS 时生效
# LLM_REFINE_DEFAULT_MODE="refine"

# 追加到 prompt 末尾的后缀 [默认: 空]，例如 /no_think
# LLM_PROMPT_SUFFIX=""
# 采样温度，0.0-2.0，越低越确定 [默认: 0.2]
# LLM_TEMPERATURE="0.2"

# 润色/翻译时携带的上下文条数（已完成的原文+译文对）
# 每次请求从 min 起步 +1 增长到 max，到顶后重置回 min [默认: 5 / 5]
# LLM_REFINE_CONTEXT_MIN_COUNT="5"
# LLM_REFINE_CONTEXT_MAX_COUNT="5"

# 单次输出最大 token，1-8192 [默认: 1024]
# LLM_REFINE_MAX_TOKENS="1024"

# 每次 LLM 请求附加的额外 HTTP 头（JSON 对象），会并入并可覆盖默认头
# LLM_REQUEST_HEADERS='{"X-Custom-Header": "value"}'
# 每次 LLM 请求体合并的额外顶层字段（JSON 对象）
# LLM_REQUEST_JSON='{"provider": {"order": ["google-vertex"]}}'


# ================================ OSC / OSCQuery ============================
# 启用 OSCQuery 自动发现 [默认: 1]
# OSC_QUERY_ENABLED="1"
# OSCQuery 公布的应用名 [默认: DeafaultAppName]
# OSCQUERY_APP_NAME="RealtimeSubtitle"


# ===================== IPC（realtime-subtitle <-> Yakutan） =================
# 启用 IPC [默认: True]
# IPC_ENABLED="True"
# IPC 服务监听地址 [默认: 127.0.0.1]（端口在 17353-17363 范围内自动选择）
# IPC_HOST="127.0.0.1"
# IPC 发现文件路径 [默认: 系统临时目录下自动生成]
# IPC_DISCOVERY_FILE=""
