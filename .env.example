# ============================================================================
# realtime-subtitle configuration example
#
# Usage: copy this file to .env, then uncomment and edit as needed.
#   - Every option has a built-in default; unset options use that default.
#   - Booleans accept 1/true/yes/y/on (true) or 0/false/no/n/off (false).
#   - The [default: xxx] note shows the value used when left unset.
#   - Never commit a .env containing real secrets to version control.
# ============================================================================


# ==================== Subtitle-server (hosted / relay mode) =================
# Optional. When set, the app can run as a client of a subtitle-server instance:
# instead of connecting to Soniox/Gemini with your own key, you sign in with
# VRChat (profile proof) and all traffic is relayed through the server, billed
# per second. The user picks "hosted" vs "own key" on first launch (and can
# switch later in Settings). Leave unset to keep the classic direct mode only.
# The server URL is read ONLY from here; it is not editable in the UI.
# SUBTITLE_SERVER_URL="https://subtitle.example.com"
#
# Version embedded in this client build. Hosted mode compares it with the
# server's configured latest/minimum versions. [default: 0.1.0]
# CLIENT_VERSION="0.1.0"
#
# Optional pre-configured account token (long-lived ss_ key). Normally obtained
# via the in-app sign-in flow; set here only for unattended/kiosk deployments.
# SUBTITLE_SERVER_TOKEN=""


# ============================ Translation/STT backend =======================
# Which backend to use: soniox | gemini
# Normally chosen interactively at startup and written back to .env; you can
# pre-set it here. In hosted mode this selects which connect endpoint
# (/relay/soniox/connect or /relay/gemini/connect) mints the actual WebSocket URL.
# TRANSLATION_PROVIDER="soniox"


# ================================= Soniox ===================================
# Persistent API key (when set, the temporary-key dispenser is not used)
# SONIOX_API_KEY=""

# Temporary-key dispenser service (used when no persistent key is configured)
# SONIOX_TEMP_KEY_URL="https://your-dispenser.example.com"
# Extra HTTP headers sent when requesting a temporary key (JSON object string)
# SONIOX_TEMP_KEY_HEADERS='{"Authorization": "Bearer your-token"}'

# WebSocket endpoint [default: wss://stt-rt.soniox.com/transcribe-websocket]
# Regional endpoints: US=stt-rt.soniox.com / EU=stt-rt.eu.soniox.com / JP=stt-rt.jp.soniox.com
# SONIOX_WEBSOCKET_URL="wss://stt-rt.soniox.com/transcribe-websocket"

# Proactive stream rollover: only for direct Soniox temporary-key streams,
# which have a hard lifetime. Ignored for hosted relay and persistent keys.
# SONIOX_STREAM_DURATION_SECONDS="170"

# Cost saver: close the active provider WebSocket after long local silence,
# reopen on speech. Applies to Soniox and Gemini.
# [default: True when a persistent provider API key is set, False for temp keys]
# SLEEP_ON_SILENCE="True"
# SLEEP_IDLE_SECONDS="30"            # silence before sleeping [default: 30]
# SLEEP_PRE_ROLL_SECONDS="1.0"       # pre-roll audio replayed on wake [default: 1.0]
# SLEEP_SPEECH_WINDOW_SECONDS="0.75" # recent window for speech confirmation [default: 0.75]
# SLEEP_SPEECH_GRACE_SECONDS="0.5"   # speech required within that window [default: 0.5]
# SLEEP_VAD_THRESHOLD="0.2"          # Silero VAD speech probability threshold [default: 0.5]


# ================================= Gemini ===================================
# Persistent API key
# GEMINI_API_KEY=""

# Temporary-key dispenser and request headers (same as Soniox)
# GEMINI_TEMP_KEY_URL="https://your-dispenser.example.com"
# GEMINI_TEMP_KEY_HEADERS='{"Authorization": "Bearer your-token"}'

# Live API endpoint [default: the line below]
# GEMINI_WEBSOCKET_URL="wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1beta.GenerativeService.BidiGenerateContent"
# Model [default: gemini-3.5-live-translate-preview]
# GEMINI_MODEL="gemini-3.5-live-translate-preview"

# Proactive stream rollover (seconds, must be > 0)
# GEMINI_STREAM_DURATION_SECONDS="170"

# Provider-specific sleep overrides are also accepted, e.g. GEMINI_SLEEP_ON_SILENCE.

# Convert a half-width , . ? ! sitting between two CJK chars to full-width ，。？！ [default: True]
# GEMINI_FULLWIDTH_PUNCT_FIX="True"

# Reshape/reorder Arabic/Hebrew text before sending it to VRChat OSC chatbox [default: True]
# ENABLE_ARABIC_RESHAPER="True"


# ========================= Translation target / mode ========================
# Use the system language as the translation target automatically [default: True]
# When False, use the manually specified TARGET_LANG below.
# USE_SYSTEM_LANGUAGE="True"

# Manually specified target language (used when USE_SYSTEM_LANGUAGE=False)
# TARGET_LANG="ja"
# Language pair for two-way translation (used when TRANSLATION_MODE=two_way)
# TARGET_LANG_1="en"
# TARGET_LANG_2="zh"

# Translation mode: none (off) | one_way | two_way [default: one_way]
# TRANSLATION_MODE="one_way"

# OSC text selection: smart (send translation; send source when same language) |
#   translation_only (translation only) | source_only (source only) [default: smart]
# OSC_SEND_TEXT_MODE="smart"

# Default sentence segmentation: translation (Soniox <end> marker) |
#   endpoint (endpoint detection) | punctuation (sentence-ending punctuation) [default: punctuation]
# DEFAULT_SEGMENT_MODE="punctuation"

# Repair short speaker interruptions in noisy VRChat rooms (Soniox only):
# if A speaks, B briefly interrupts, then A resumes quickly, retract A's
# first fragment and send A1+A2 as one sentence to the LLM [default: True].
# SONIOX_INTERRUPT_REPAIR_ENABLED="True"
# Maximum duration for the interrupting speaker [default: 300 ms]
# SONIOX_INTERRUPT_MAX_DURATION_MS="300"
# Maximum gap from interrupt end to original speaker resume [default: 1000 ms]
# SONIOX_INTERRUPT_RESUME_GAP_MS="1000"
# Require the interrupting speaker text to match the filler whitelist after
# lowercasing and removing punctuation/symbols [default: True]
# SONIOX_INTERRUPT_FILLER_WHITELIST_ENABLED="True"
# Comma-separated filler whitelist. Matching is exact after normalization.
# SONIOX_INTERRUPT_FILLER_WHITELIST="啊,阿,呀,哎,唉,诶,欸,嗯,恩,唔,呃,额,呜,哦,噢,喔,嗷,哼,嗯嗯,呃呃,哦哦,啊啊,哎呀,哎哟,uh,uhh,uh-huh,um,umm,erm,er,ah,oh,o,ooh,oooh,eh,huh,hm,hmm,mm,mmm,yeah,yep,ya,yes,mhm,mhmm,うん,ううん,うーん,うわ,え,ええ,あ,ああ,お,おお,ほう,へえ,ふむ,ん,あの,えっと,まあ,えへ,えへへ,はい,はいはい,そう,そうそう,そうそうそう,そっか,なるほど,어,어어,음,응,응응,아,아아,오,에,으음,흠,네,네네,맞아,맞아맞아"


# =============================== UI / behavior ==============================
# Open the built-in WebView window on startup [default: True]
# When False, only print the URL in the console; open a browser yourself
# (closing the page will not exit the program).
# AUTO_OPEN_WEBVIEW="True"

# Lock manual controls: hide frontend restart/pause/audio-source/OSC buttons and
# disable the related backend operations [default: False]
# LOCK_MANUAL_CONTROLS="False"

# Speaker diarization (Soniox only; forced off for Gemini) [default: True]
# ENABLE_SPEAKER_DIARIZATION="True"

# Hide speaker labels (even when diarization is enabled) [default: False]
# HIDE_SPEAKER_LABELS="False"

# Enable the chroma (green-screen) theme: adds it to the theme cycle; switching
# to it disables window always-on-top [default: False]
# ENABLE_CHROMA_THEME="False"

# Write transcript logs to the logs/ folder [default: False]
# ENABLE_TRANSCRIPT_LOG="True"


# ============================ Audio source / capture ========================
# Transcribe Twitch livestream audio (streamlink pulls the stream, ffmpeg
# extracts 16kHz mono PCM) [default: False, i.e. capture local system/mic audio]
# USE_TWITCH_AUDIO_STREAM="False"
# TWITCH_CHANNEL=""                  # channel name (without the https://www.twitch.tv/ prefix)
# TWITCH_STREAM_QUALITY="audio_only" # quality preference (usually audio_only / best)
# FFMPEG_PATH="ffmpeg"               # ffmpeg executable path [default: found on PATH]

# Mute the microphone component when VRChat MuteSelf=true [default: True]
# MUTE_MIC_WHEN_VRCHAT_SELF_MUTED="True"
# Optional fallback device IDs. Empty means the current system default; browser settings override them.
# OUTPUT_DEVICE_ID=""
# MICROPHONE_DEVICE_ID=""

# Mix weights (only effective for the mix audio source): self=microphone,
# others=system loopback. Set just one; the other becomes 1 - value. Range 0.0-1.0 [default: 0.5]
# MIX_OWN_VOLUME="0.5"


# ================================ Web server ================================
# Listen address [default: 0.0.0.0]
# When AUTO_OPEN_WEBVIEW=True it is forced to 127.0.0.1; when disabled it
# defaults to 0.0.0.0 for LAN access.
# SERVER_HOST="0.0.0.0"
# Port [default: 8080]; set to 0 to auto-select an available port.
# SERVER_PORT="8080"


# ===================== LLM refine / translate (OpenAI-compatible) ===========
# Used to lightly refine completed translation segments for accuracy and fluency. Requires
# BASE_URL, API_KEY and MODEL to all be set to take effect.
# LLM_BASE_URL="https://openrouter.ai/api/v1"
# Supports multiple comma-separated keys, used round-robin at runtime.
# LLM_API_KEY=""
# LLM_MODEL="openai/gpt-oss-120b:google-vertex"

# Enable LLM refine by default at startup [default: True]
# LLM_REFINE_DEFAULT_ENABLED="True"
# Default mode: off | refine | translate [default: follows the line above —
# refine if enabled, otherwise off]
# Effective only when the browser has no stored history, or LOCK_MANUAL_CONTROLS is on.
# LLM_REFINE_DEFAULT_MODE="refine"

# Suffix appended to the end of the prompt [default: empty], e.g. /no_think
# LLM_PROMPT_SUFFIX=""
# Sampling temperature, 0.0-2.0, lower is more deterministic [default: 0.2]
# LLM_TEMPERATURE="0.2"

# Number of context items (completed source+translation pairs) sent for refine/translate.
# Each request starts at min, grows by +1 up to max, then resets to min [default: 5 / 5]
# LLM_REFINE_CONTEXT_MIN_COUNT="5"
# LLM_REFINE_CONTEXT_MAX_COUNT="5"

# Max output tokens per request, 1-8192 [default: 1024]
# LLM_REFINE_MAX_TOKENS="1024"

# Extra HTTP headers added to every LLM request (JSON object); merged into and
# may override the default headers.
# LLM_REQUEST_HEADERS='{"X-Custom-Header": "value"}'
# Extra top-level fields merged into every LLM request body (JSON object).
# LLM_REQUEST_JSON='{"provider": {"order": ["google-vertex"]}}'
# Tip: DeepSeek reasoning models (e.g. deepseek-v4-flash) think by default,
# which adds seconds of latency and can burn the whole token budget (empty
# replies). Disable it for realtime subtitle use:
# LLM_REQUEST_JSON='{"thinking": {"type": "disabled"}}'

# Diagnostic JSONL log of every LLM call, refine decision, and sentence-pairing
# close (logs/llm_<timestamp>.jsonl; analyze with tools/llm_log_report.py).
# Off by default -- enable when collecting data for tuning/debugging. [default: 0]
# ENABLE_LLM_LOG="1"

# Capture every raw Soniox WebSocket response batch together with the active
# segmentation/translation modes. Files are written to
# logs/soniox-responses/responses_<timestamp>_*.jsonl.
# Off by default; responses contain recognized speech text. [default: 0]
# SONIOX_RESPONSE_LOG="1"

# Capture every frame broadcast to frontend WebSocket clients under
# logs/frontend-frames/frames_<timestamp>_*.jsonl. Off by default; frames may
# contain recognized and translated speech text. [default: 0]
# FRONTEND_FRAME_LOG="1"


# ================================ OSC / OSCQuery ============================
# Enable OSCQuery auto-discovery [default: 1]
# OSC_QUERY_ENABLED="1"
# Application name advertised by OSCQuery [default: DeafaultAppName]
# OSCQUERY_APP_NAME="RealtimeSubtitle"


# ===================== IPC (realtime-subtitle <-> Yakutan) =================
# Enable IPC [default: True]
# IPC_ENABLED="True"
# IPC server listen address [default: 127.0.0.1] (port auto-selected in 17353-17363)
# IPC_HOST="127.0.0.1"
# IPC discovery file path [default: auto-generated under the system temp dir]
# IPC_DISCOVERY_FILE=""
