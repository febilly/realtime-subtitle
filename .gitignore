# Minimal .gitignore for this Python project
# Only ignore files/folders that are definitely not needed in the repo

# Virtual environment used for building/running locally
venv/
venv_build/
.venv/

# Python cache and bytecode
__pycache__/
*.py[cod]
*.pyo

# Build / distribution
build/
dist/
*.egg-info/

# Logs and runtime transcripts (large, generated)
logs/
*.log

# Cloudflare Wrangler local state/cache
.wrangler/

# Environment file that may contain secrets (incl. backups like .env.bak)
.env
.env.*
# ...but keep the committed templates (no secrets)
!.env.example
!.env.example.zh

# Local scratch/reference files
reference.py

# OS metadata
.DS_Store
Thumbs.db

# Test cache
.pytest_cache/

# *.spec

.codex/

.deepseek/

# Local scratch directory
scratch/

*.ttc

# Claude helper directories
.claude/